# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
*.tsbuildinfo

# Stray compiled output emitted next to TS sources by a bare `tsc` run.
# Under ESM `.js` import specifiers these shadow the real `.ts` (vitest/node load
# the stale `.js`), so they must never be tracked. Real source here is .ts/.tsx.
apps/api/src/**/*.js
apps/api/src/**/*.d.ts
apps/api/src/**/*.js.map
apps/api/test/**/*.js
apps/api/test/**/*.d.ts
apps/api/jobs/**/*.js
apps/api/scripts/**/*.js

# Local databases (never commit runtime data)
*.db
*.db-shm
*.db-wal
data/

# Secrets — only .env.example is ever tracked
.env
.env.*
!.env.example

# Logs
*.log
logs/

# Agent worktrees (if used)
.claude/worktrees/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.local

# Test / coverage
coverage/
.vitest/
