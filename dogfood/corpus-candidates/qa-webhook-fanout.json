  "keyDecisions": [
    {
      "decision": "Webhook ingest compute model",
      "chosen": "Lambda behind API Gateway",
      "alternativesConsidered": [
        "Fargate/ECS service",
        "EC2 instance"
      ],
      "rationale": "Cost optimization + reliability: ~$0 idle floor, scales instantly with spike volume, no always-on instance to patch or load-balance."
    },
    {
      "decision": "Fan-out topology: SNS → per-consumer SQS vs direct Lambda invocation",
      "chosen": "SNS topic → per-consumer SQS queues → consumer Lambdas",
      "alternativesConsidered": [
        "Lambda invoking downstream Lambdas directly",
        "EventBridge bus as sole fan-out"
      ],
      "rationale": "Reliability: SNS→SQS gives each consumer an independent retry buffer and DLQ, so one slow consumer never blocks others and no events are lost on downstream failure."
    },
    {
      "decision": "Idempotency store for consumer deduplication",
      "chosen": "DynamoDB conditional writes keyed on webhook event ID",
      "alternativesConsidered": [
        "ElastiCache (Redis SETNX)",
        "No deduplication"
      ],
      "rationale": "Reliability + cost optimization: DynamoDB on-demand needs no VPC, no always-on node, and a TTL-based cleanup handles the deduplication window automatically."
    },
    {
      "decision": "Balanced tier step-up: private VPC topology",
      "chosen": "Keep Lambda + DynamoDB serverless-no-VPC; add multi-AZ redundancy via SQS/SNS managed HA and provisioned Lambda concurrency",
      "alternativesConsidered": [
        "Move consumers into Fargate/ECS in private subnets",
        "Add RDS for event log"
      ],
      "rationale": "Cost optimization + performance efficiency: fully serverless stack gains multi-AZ durability from managed services without paying for NAT gateways or always-on containers."
    },
    {
      "decision": "Resilient tier: cross-region DR mechanism",
      "chosen": "DynamoDB Global Tables + EventBridge global bus with API destinations for cross-region consumer delivery",
      "alternativesConsidered": [
        "Active-passive RDS cross-region replica",
        "Manual DynamoDB backup + restore"
      ],
      "rationale": "Reliability: Global Tables gives active-active idempotency state with sub-second replication; EventBridge API destinations enable regional failover of consumer delivery without re-architecting."
    }
  ],
  "securityFloor": [
    "Encrypt all data at rest (KMS / service-native SSE), preferring customer-managed keys.",
    "Enforce TLS in transit everywhere; terminate HTTPS at the edge and reject plaintext.",
    "Least-privilege IAM: scoped per-service roles, no wildcards, no long-lived access keys.",
    "Enable S3 Block Public Access account-wide so no bucket or object can be made public.",
    "Keep the data tier private: VPC-bound stores in private subnets with no public route; managed/serverless stores (DynamoDB/S3) are already private via IAM and need no VPC or NAT.",
    "Store secrets in AWS Secrets Manager / SSM Parameter Store — never in code or images.",
    "Front public endpoints with CloudFront + AWS WAF (managed + rate-based rules); Shield Standard for L3/L4.",
    "Enable CloudTrail plus S3/CloudFront/ALB access logs and VPC Flow Logs for audit."
