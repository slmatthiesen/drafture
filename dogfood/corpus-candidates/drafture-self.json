  "keyDecisions": [
    {
      "decision": "Compute model for API + generation tier",
      "chosen": "Lambda behind API Gateway (HTTP API)",
      "alternativesConsidered": [
        "Fargate/ECS + ALB",
        "EC2 single-box",
        "App Runner"
      ],
      "rationale": "Cost-optimization pillar wins decisively: scale-to-zero + pay-per-request matches a mostly-idle workload; Lambda's 15-min timeout covers the ~1–2 min LLM round-trip with no always-on EC2/ALB/NAT floor."
    },
    {
      "decision": "Primary datastore for designs, votes, pricing, and operator notes",
      "chosen": "DynamoDB (on-demand) — single table, status GSI for review queue",
      "alternativesConsidered": [
        "RDS Postgres (Aurora Serverless v2)",
        "S3 + JSON files",
        "Firebase/Firestore"
      ],
      "rationale": "Reliability + cost-optimization: key-value/status-filter access patterns need no relational joins; DynamoDB on-demand gives $0 idle cost, auto-scales writes, and absorbs read spikes without capacity planning."
    },
    {
      "decision": "Corpus vector storage and retrieval",
      "chosen": "Single S3 object (JSON blob of id→vector pairs), loaded into Lambda memory per generation invocation",
      "alternativesConsidered": [
        "OpenSearch k-NN",
        "Pinecone / external vector DB",
        "DynamoDB binary attribute per design"
      ],
      "rationale": "Performance-efficiency + cost-optimization: a few-hundred-vector corpus makes a managed vector index gross over-engineering; an in-process cosine loop over an S3-fetched blob is sub-millisecond and costs ~$0."
    },
    {
      "decision": "Frontend delivery and API edge protection",
      "chosen": "S3 static origin + CloudFront distribution with WAF (managed rules + rate-based rule)",
      "alternativesConsidered": [
        "Amplify Hosting",
        "Vercel/Netlify (off-AWS)",
        "API Gateway regional with no CDN"
      ],
      "rationale": "Operational-excellence + security: CloudFront caches the read-heavy gallery/SEO pages at the edge (primary read-scale mechanism) while WAF rate-limits the generation endpoint, all on one distribution."
    },
    {
      "decision": "Operator review queue access control",
      "chosen": "Cognito User Pool (single operator user), JWT authorizer on API Gateway admin routes",
      "alternativesConsidered": [
        "API key in Secrets Manager",
        "IAM console access only",
        "Basic auth in Lambda"
      ],
      "rationale": "Security pillar: Cognito gives short-lived JWTs, MFA, and audit without managing credentials in code; one user pool costs ~$0 at one operator."
    },
    {
      "decision": "Pricing table refresh mechanism",
      "chosen": "EventBridge Scheduler rule → Lambda refresher → DynamoDB upsert",
      "alternativesConsidered": [
        "Hard-coded in Lambda bundle",
        "Manual operator update via admin API",
        "S3 CSV polled by Lambda on each request"
      ],
      "rationale": "Operational-excellence: a scheduled refresh decouples pricing updates from deploys and keeps the hot read path to a single DynamoDB GetItem, with no always-on process."
    }
  ],
