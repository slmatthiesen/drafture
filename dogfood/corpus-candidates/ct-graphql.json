  "keyDecisions": [
    {
      "decision": "Budget compute shape",
      "chosen": "Single EC2 t4g.small (Docker Compose: GraphQL container + Redis + Postgres)",
      "alternativesConsidered": [
        "Fargate + RDS + NAT gateway (~$100+/mo always-on floor)",
        "Lambda + Aurora Serverless (poor fit: GraphQL servers are long-lived, connection-pool-heavy)"
      ],
      "rationale": "Cost-optimization pillar: co-locating on one public-subnet instance keeps idle floor ~$15/mo; Fargate/RDS split is the balanced step-up where multi-AZ actually justifies it."
    },
    {
      "decision": "Balanced/resilient compute model",
      "chosen": "Fargate (ECS) behind ALB in private subnets, multi-AZ",
      "alternativesConsidered": [
        "EC2 ASG (operational overhead, slower scale-out)",
        "Lambda (connection-pool churn kills relational DB at scale)"
      ],
      "rationale": "Reliability + operational excellence: Fargate removes instance management, ALB spreads across AZs, and ECS service auto-scaling handles sustained traffic growth."
    },
    {
      "decision": "Relational datastore (balanced/resilient)",
      "chosen": "Aurora Postgres (db.t4g.medium writer)",
      "alternativesConsidered": [
        "RDS Postgres Multi-AZ (no read replicas, slower failover)",
        "DynamoDB (GraphQL resolvers expect relational joins)"
      ],
      "rationale": "Reliability + performance efficiency: Aurora's shared-storage multi-AZ failover is ~30s vs RDS ~60-120s, and reader endpoints scale reads without schema changes."
    },
    {
      "decision": "Cache layer",
      "chosen": "ElastiCache Redis (cache.t4g.micro at budget on-box; cache.t4g.small managed at balanced+)",
      "alternativesConsidered": [
        "DAX (DynamoDB-only, not applicable)",
        "Application-level in-process cache (lost on container restart, no shared state across tasks)"
      ],
      "rationale": "Performance efficiency: a shared Redis layer absorbs hot GraphQL query results across all container tasks, protecting the DB from read bursts."
    },
    {
      "decision": "Budget datastore placement",
      "chosen": "Self-managed Postgres + Redis bound to localhost on the EC2 box",
      "alternativesConsidered": [
        "RDS/ElastiCache in private subnet (adds NAT gateway ~$33/mo always-on, no robustness gain at single-instance budget)",
        "Aurora Serverless v2 (minimum ACU floor adds cost; connection overhead suits serverless, not a container)"
      ],
      "rationale": "Cost-optimization + no-public-data-tier: localhost-bound stores are already off the public internet behind the host SG, satisfying the security floor without a private subnet or NAT."
    }
  ],
