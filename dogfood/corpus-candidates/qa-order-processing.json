  "keyDecisions": [
    {
      "decision": "Compute model for checkout ingest and fulfillment worker",
      "chosen": "Lambda behind API Gateway (serverless-no-VPC)",
      "alternativesConsidered": [
        "Fargate + ALB + ECS",
        "EC2 ASG behind ALB"
      ],
      "rationale": "Cost optimization + reliability: ~$0 idle floor, scales to burst automatically, no always-on NAT/ALB/instance bill at <50k/mo traffic."
    },
    {
      "decision": "Primary datastore for order records",
      "chosen": "DynamoDB on-demand",
      "alternativesConsidered": [
        "Aurora Serverless v2 (Postgres)",
        "RDS Postgres single-AZ"
      ],
      "rationale": "Performance efficiency + cost: on-demand capacity absorbs checkout spikes without pre-provisioning; no VPC/NAT required; key-based order lookup fits the access pattern."
    },
    {
      "decision": "Async decoupling mechanism between checkout and fulfillment",
      "chosen": "SQS standard queue with DLQ",
      "alternativesConsidered": [
        "SNS direct invoke",
        "EventBridge pipe",
        "Kinesis Data Streams"
      ],
      "rationale": "Reliability: SQS at-least-once delivery with configurable visibility timeout and DLQ is the lowest-complexity durable buffer; idempotent consumer handles redelivery."
    },
    {
      "decision": "Idempotency for fulfillment worker",
      "chosen": "DynamoDB conditional write on orderId (idempotency key)",
      "alternativesConsidered": [
        "Lambda Powertools idempotency utility (DynamoDB-backed)",
        "SQS FIFO dedup ID"
      ],
      "rationale": "Reliability: a conditional PutItem on orderId makes fulfillment processing exactly-once even under SQS redelivery, with no extra service dependency."
    },
    {
      "decision": "Order status notification to end user",
      "chosen": "SES transactional email + per-order DynamoDB delivery record (outbox pattern)",
      "alternativesConsidered": [
        "SNS email subscription",
        "bare SES fire-and-forget"
      ],
      "rationale": "Reliability: outbox (write pending→publish→flip delivered) gives observable, retryable delivery status and prevents silent loss on exactly-once billing transitions."
    }
  ],
