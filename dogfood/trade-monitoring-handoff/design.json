  "keyDecisions": [
    {
      "decision": "Compute model for the ingest endpoint",
      "chosen": "Lambda behind API Gateway (HTTP API)",
      "alternativesConsidered": [
        "EC2/Fargate always-on container",
        "App Runner"
      ],
      "rationale": "At <1k/mo the per-invocation model costs cents vs always-on VMs at ~$15–50/mo floor; reliability pillar is satisfied because Lambda runs across multiple AZs by default, meeting best-effort tolerance."
    },
    {
      "decision": "Webhook authenticity — TradingView has no HMAC; use shared-secret token",
      "chosen": "Bearer token / passphrase in Authorization header validated in Lambda before any side-effect",
      "alternativesConsidered": [
        "HMAC-SHA256 signature (ideal but TradingView does not sign payloads)",
        "API Gateway API key (no replay protection)"
      ],
      "rationale": "A secret bearer token in the TradingView alert message is the only feasible tamper-detection mechanism the platform supports; Lambda rejects mismatched tokens before writing, preventing forged signals and billing fraud."
    },
    {
      "decision": "Canonical trade store",
      "chosen": "DynamoDB on-demand (single table, tradeId partition key)",
      "alternativesConsidered": [
        "Aurora Serverless v2 Postgres",
        "S3-only flat files"
      ],
      "rationale": "On-demand DynamoDB has zero idle cost, scales instantly to any burst, and the AI step can query or stream via DynamoDB Streams — performance efficiency + cost optimization pillars win at this traffic level."
    },
    {
      "decision": "Fan-out to existing frontend",
      "chosen": "SQS queue → Lambda dispatcher → HTTP POST to existing endpoint",
      "alternativesConsidered": [
        "Direct synchronous HTTP call from ingest Lambda",
        "EventBridge pipe"
      ],
      "rationale": "Decoupling ingest from delivery via SQS means a slow or failing downstream cannot block or lose the ingest write; reliability pillar: at-least-once + DLQ absorbs transient frontend outages."
    },
    {
      "decision": "AI evaluation step (future) — pre-wire stub now",
      "chosen": "S3 data lake + stub Lambda triggered by DynamoDB Streams",
      "alternativesConsidered": [
        "Dump to RDS for SQL queries",
        "Build full AI step now"
      ],
      "rationale": "Writing raw signals to S3 (Parquet/JSON) from a Streams-triggered Lambda is zero-cost at this volume and gives the Python evaluation job a durable, queryable dataset without blocking current scope."
    }
  ],
