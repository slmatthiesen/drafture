  "keyDecisions": [
    {
      "decision": "Compute model for webhook ingest + eval",
      "chosen": "Lambda (serverless) behind API Gateway HTTP API",
      "alternativesConsidered": [
        "Fargate/ECS always-on container",
        "EC2 single instance"
      ],
      "rationale": "At <1k/mo and best-effort SLA, Lambda's per-invocation billing means near-$0 idle cost (Cost Optimization), and the 15-min timeout fully covers Python eval jobs without an always-on NAT/ALB bill."
    },
    {
      "decision": "Async decoupling between ingest and AI eval",
      "chosen": "SQS queue (Standard in budget, FIFO in balanced/resilient) with DLQ + idempotent consumer",
      "alternativesConsidered": [
        "Synchronous Lambda chaining (ingest calls eval directly)",
        "EventBridge as primary ingest bus"
      ],
      "rationale": "SQS decouples the 200ms webhook response from the slow eval job, absorbs retry/backoff automatically, and the DLQ ensures no trade is silently lost (Reliability pillar)."
    },
    {
      "decision": "Primary datastore for trades and eval results",
      "chosen": "DynamoDB (on-demand, with PITR)",
      "alternativesConsidered": [
        "RDS Postgres (requires VPC + NAT ~$33/mo always-on)",
        "Aurora Serverless v2"
      ],
      "rationale": "Trade records are key-value access patterns (by trade ID, ticker, timestamp) — DynamoDB on-demand needs no VPC/NAT, scales to zero at idle, and PITR covers durability (Cost Optimization + Reliability)."
    },
    {
      "decision": "TradingView webhook authentication",
      "chosen": "HMAC-SHA256 signature verification in ingest Lambda with replay-window timestamp check",
      "alternativesConsidered": [
        "API key header only",
        "No authentication (public endpoint)"
      ],
      "rationale": "TradingView supports a secret token in the alert payload; verifying an HMAC + timestamp before any side-effect prevents spoofed alerts from injecting fake trades or triggering spurious AI eval runs (Security pillar)."
    },
    {
      "decision": "Market-data credentials for AI eval worker",
      "chosen": "Secrets Manager with rotation, fetched at runtime by eval Lambda",
      "alternativesConsidered": [
        "Environment variable in Lambda config",
        "SSM Parameter Store SecureString"
      ],
      "rationale": "Secrets Manager gives automatic rotation and fine-grained IAM access without baking credentials into the function config or image (Security pillar)."
    },
    {
      "decision": "Multi-region DR mechanism (resilient tier only)",
      "chosen": "DynamoDB Global Tables + Route 53 health-check failover + EventBridge cross-region bus",
      "alternativesConsidered": [
        "Single-region with daily RDS snapshot restore",
        "Pilot-light with manual promotion"
      ],
      "rationale": "Global Tables gives active-active data replication with sub-second RPO; R53 health-check failover provides automatic RTO without manual intervention — the only combination that satisfies a genuine DR objective (Reliability pillar)."
    }
  ],
